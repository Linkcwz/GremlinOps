# Git transport policy — the ONE file hooks and sync scripts read.
# Agents follow this file, never their priors about which remote is canonical.
#
# Normal mode: the private remote is canonical, the public remote mirrors a
# sanitized tree (see .githooks/post-commit).
#
# During a private-remote outage, flip MODE=fallback, point REMOTE/BRANCH at
# the fallback target, and add a dated note to the constitution. When
# repaired: reconcile the fallback branch back, restore normal values, remove
# the note.

GREMLIN_GIT_POLICY_MODE=normal
GREMLIN_GIT_REMOTE=origin
GREMLIN_GIT_BRANCH=main
GREMLIN_GIT_NORMAL_REMOTE=origin
GREMLIN_GIT_NORMAL_BRANCH=main
