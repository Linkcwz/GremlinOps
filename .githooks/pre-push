#!/usr/bin/env bash
set -u

# pre-push SAFETY net: block private-only files from being pushed to the
# PUBLIC mirror. Unlike the discipline hooks, this applies to EVERYONE —
# operator included — because the harm it prevents (a secret or personal
# record reaching a public remote) is irreversible. See the doctrine:
# discipline hooks no-op for the operator; safety hooks never do.
#
# Configure:
#   PUBLIC_REMOTE_MATCH  pattern identifying your public remote
#   PRIVATE_PATHS        exact in-repo paths that must never go public
#   PRIVATE_TREES        directory prefixes that must never go public

PUBLIC_REMOTE_MATCH='github.com[:/]YourOrg/YourRepo'
PRIVATE_PATHS=(
  "private/credentials.md"
  "Agents/SSH/id_ed25519"
)
PRIVATE_TREES=(
  "private-records/"
)

remote_name=${1:-}
remote_url=${2:-}

if ! printf '%s %s' "$remote_name" "$remote_url" | grep -qE "$PUBLIC_REMOTE_MATCH"; then
  exit 0
fi

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$local_sha" in
    0000000000000000000000000000000000000000) continue ;;
  esac

  for p in "${PRIVATE_PATHS[@]}"; do
    if git cat-file -e "$local_sha:$p" 2>/dev/null; then
      printf 'pre-push blocked: %s is private-only and must not reach the public remote.\n' "$p" >&2
      blocked=1
    fi
  done

  for t in "${PRIVATE_TREES[@]}"; do
    if git ls-tree -r --name-only "$local_sha" -- "$t" 2>/dev/null | grep -q .; then
      printf 'pre-push blocked: %s holds private-only records and must not reach the public remote.\n' "$t" >&2
      blocked=1
    fi
  done
done

if [[ $blocked -ne 0 ]]; then
  printf 'Keep private paths on the private remote only, or push a sanitized tree (see .githooks/post-commit).\n' >&2
fi
exit "$blocked"
